{
  "name": "claude-code-workflow",
  "displayName": "Claude Code Workflow",
  "description": "Delivery cadence toolkit for Claude Code projects — session checklist, API auditing, decision log, DoD, patterns library, tech debt, Azure DevOps sync",
  "version": "0.5.0",
  "icon": "media/icon.png",
  "publisher": "agmenzies",
  "repository": {
    "type": "git",
    "url": "https://github.com/agmenzies/claude-code-workflow.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Linters"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "agents",
    "workflow",
    "api",
    "openapi",
    "delivery"
  ],
  "activationEvents": [
    "workspaceContains:.claude/skills"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeWorkflow.updateTests",
        "title": "Update Tests from History",
        "category": "Claude Workflow",
        "icon": "$(beaker)"
      },
      {
        "command": "claudeWorkflow.updateUAT",
        "title": "Update UAT Spec",
        "category": "Claude Workflow",
        "icon": "$(checklist)"
      },
      {
        "command": "claudeWorkflow.regression",
        "title": "Run Regression Suite",
        "category": "Claude Workflow",
        "icon": "$(run-all)"
      },
      {
        "command": "claudeWorkflow.syncDesign",
        "title": "Sync Design Standards",
        "category": "Claude Workflow",
        "icon": "$(symbol-color)"
      },
      {
        "command": "claudeWorkflow.doneCheck",
        "title": "Definition of Done Check",
        "category": "Claude Workflow",
        "icon": "$(tasklist)"
      },
      {
        "command": "claudeWorkflow.auditApi",
        "title": "Audit API",
        "category": "Claude Workflow",
        "icon": "$(shield)"
      },
      {
        "command": "claudeWorkflow.syncApiDocs",
        "title": "Sync API Docs",
        "category": "Claude Workflow",
        "icon": "$(file-code)"
      },
      {
        "command": "claudeWorkflow.logDecision",
        "title": "Log Decision",
        "category": "Claude Workflow",
        "icon": "$(milestone)"
      },
      {
        "command": "claudeWorkflow.capturePattern",
        "title": "Capture Pattern",
        "category": "Claude Workflow",
        "icon": "$(extensions)"
      },
      {
        "command": "claudeWorkflow.logFailure",
        "title": "Log Failure Mode",
        "category": "Claude Workflow",
        "icon": "$(bug)"
      },
      {
        "command": "claudeWorkflow.logDebt",
        "title": "Log Tech Debt",
        "category": "Claude Workflow",
        "icon": "$(flame)"
      },
      {
        "command": "claudeWorkflow.releaseNotes",
        "title": "Generate Release Notes",
        "category": "Claude Workflow",
        "icon": "$(tag)"
      },
      {
        "command": "claudeWorkflow.postReview",
        "title": "Post-Implementation Review",
        "category": "Claude Workflow",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "claudeWorkflow.updatePlaybooks",
        "title": "Update Agent Playbooks",
        "category": "Claude Workflow",
        "icon": "$(robot)"
      },
      {
        "command": "claudeWorkflow.scaffoldSkills",
        "title": "Scaffold All Skills",
        "category": "Claude Workflow",
        "icon": "$(wand)"
      },
      {
        "command": "claudeWorkflow.syncToWiki",
        "title": "Sync Living Docs to Wiki",
        "category": "Claude Workflow",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "claudeWorkflow.syncDebtToWorkItems",
        "title": "Sync Tech Debt to Work Items",
        "category": "Claude Workflow",
        "icon": "$(issues)"
      },
      {
        "command": "claudeWorkflow.appendHistory",
        "title": "Append to Instruction History",
        "category": "Claude Workflow",
        "icon": "$(add)"
      },
      {
        "command": "claudeWorkflow.openSetup",
        "title": "Open Setup Wizard",
        "category": "Claude Workflow",
        "icon": "$(gear)"
      },
      {
        "command": "claudeWorkflow.refresh",
        "title": "Refresh",
        "category": "Claude Workflow",
        "icon": "$(refresh)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "claudeWorkflowPanel",
          "name": "Claude Code Workflow",
          "when": "claudeWorkflow.active"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "claudeWorkflow.refresh",
          "when": "view == claudeWorkflowPanel",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "claudeWorkflow.regression",
        "key": "ctrl+shift+alt+r",
        "mac": "cmd+shift+alt+r",
        "when": "claudeWorkflow.active"
      },
      {
        "command": "claudeWorkflow.updateTests",
        "key": "ctrl+shift+alt+t",
        "mac": "cmd+shift+alt+t",
        "when": "claudeWorkflow.active"
      },
      {
        "command": "claudeWorkflow.auditApi",
        "key": "ctrl+shift+alt+a",
        "mac": "cmd+shift+alt+a",
        "when": "claudeWorkflow.active"
      },
      {
        "command": "claudeWorkflow.doneCheck",
        "key": "ctrl+shift+alt+d",
        "mac": "cmd+shift+alt+d",
        "when": "claudeWorkflow.active"
      },
      {
        "command": "claudeWorkflow.logDecision",
        "key": "ctrl+shift+alt+l",
        "mac": "cmd+shift+alt+l",
        "when": "claudeWorkflow.active"
      }
    ],
    "walkthroughs": [
      {
        "id": "claudeWorkflow.gettingStarted",
        "title": "Get started with Claude Code Workflow",
        "description": "Ship faster, forget less. Set up your delivery cadence toolkit.",
        "steps": [
          {
            "id": "openSetup",
            "title": "Run the setup wizard",
            "description": "Configure Azure DevOps and scaffold skills in one step.\n\n[Open Setup Wizard](command:claudeWorkflow.openSetup)",
            "media": { "image": "media/icon.png", "altText": "Claude Code Workflow icon" }
          },
          {
            "id": "scaffoldSkills",
            "title": "Scaffold skills",
            "description": "Create all 14 Claude Code skill files in your project.\n\n[Scaffold All Skills](command:claudeWorkflow.scaffoldSkills)",
            "media": { "image": "media/icon.png", "altText": "Scaffold skills" }
          },
          {
            "id": "runAudit",
            "title": "Run your first API audit",
            "description": "Check all routes for auth, rate limits, and Swagger coverage.\n\n[Audit API](command:claudeWorkflow.auditApi)",
            "media": { "image": "media/icon.png", "altText": "API audit" }
          },
          {
            "id": "doneCheck",
            "title": "Run Definition of Done",
            "description": "25-point quality gate — code, tests, docs, security, observability.\n\n[Run DoD Check](command:claudeWorkflow.doneCheck)",
            "media": { "image": "media/icon.png", "altText": "Definition of Done" }
          }
        ]
      }
    ],
    "configuration": {
      "title": "Claude Code Workflow",
      "properties": {
        "claudeWorkflow.claudePath": {
          "type": "string",
          "default": "claude",
          "description": "Path to the Claude Code CLI binary"
        },
        "claudeWorkflow.historyFile": {
          "type": "string",
          "default": "instruction-history.toon",
          "description": "Relative path to the instruction history file"
        },
        "claudeWorkflow.autoRemindAfterCommit": {
          "type": "boolean",
          "default": true,
          "description": "Show a reminder to update instruction history after git commits"
        },
        "claudeWorkflow.staleThresholdHours": {
          "type": "number",
          "default": 8,
          "description": "Hours since last history update before the status bar turns amber"
        },
        "claudeWorkflow.routeGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "server/routes/**/*.ts",
            "src/routes/**/*.ts",
            "routes/**/*.ts",
            "app/routes/**/*.ts",
            "server/routes/**/*.js"
          ],
          "description": "Glob patterns for route files to scan for API coverage"
        },
        "claudeWorkflow.swaggerGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "server/swagger/**/*.yaml",
            "server/swagger/**/*.yml",
            "server/swagger/**/*.json",
            "swagger/**/*.yaml",
            "openapi/**/*.yaml"
          ],
          "description": "Glob patterns for Swagger/OpenAPI documentation files"
        },
        "claudeWorkflow.publicRoutePrefixes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "/health",
            "/api/health",
            "/api/public",
            "/api/auth/login",
            "/api/auth/register"
          ],
          "description": "Route prefixes that are intentionally public (auth not required)"
        },
        "claudeWorkflow.azureDevOps.organization": {
          "type": "string",
          "default": "",
          "description": "Azure DevOps organization name (e.g. 'mycompany' from dev.azure.com/mycompany)"
        },
        "claudeWorkflow.azureDevOps.project": {
          "type": "string",
          "default": "",
          "description": "Azure DevOps project name"
        },
        "claudeWorkflow.azureDevOps.wikiRootPath": {
          "type": "string",
          "default": "/Claude Workflow",
          "description": "Root path in the wiki where living docs are synced"
        },
        "claudeWorkflow.azureDevOps.wikiId": {
          "type": "string",
          "default": "",
          "description": "Wiki ID to sync to. Leave empty to auto-discover or be prompted."
        },
        "claudeWorkflow.azureDevOps.debtWorkItemType": {
          "type": "string",
          "default": "Task",
          "description": "Azure DevOps work item type for tech debt entries (e.g. Task, Bug, User Story)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "sharp": "^0.34.5",
    "typescript": "^5.3.0"
  }
}
